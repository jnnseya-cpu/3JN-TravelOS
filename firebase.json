{
  "functions": {
    "source": ".",
    "runtime": "nodejs20",
    "ignore": [
      "frontend/**",
      "docs/**",
      "**/.git/**",
      "**/node_modules/**",
      "*.md",
      ".github/**",
      "vercel.json",
      "render.yaml",
      "Dockerfile",
      ".dockerignore"
    ]
  },
  "hosting": {
    "public": "frontend",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "/api/**", "function": "api" },
      { "source": "/shared/**", "function": "api" },
      { "source": "/", "destination": "/landing.html" },
      { "source": "/app", "destination": "/index.html" },
      { "source": "/how-it-works", "destination": "/index.html" },
      { "source": "/api-portal", "destination": "/index.html" },
      { "source": "/membership", "destination": "/index.html" },
      { "source": "/console", "destination": "/index.html" },
      { "source": "/admin", "destination": "/index.html" },
      { "source": "/business", "destination": "/index.html" },
      { "source": "/visaos", "destination": "/index.html" },
      { "source": "/marketplace", "destination": "/index.html" },
      { "source": "/blog", "destination": "/index.html" },
      { "source": "/blog/**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
          { "key": "Service-Worker-Allowed", "value": "/" }
        ]
      },
      {
        "source": "/manifest.webmanifest",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate" },
          { "key": "Content-Type", "value": "application/manifest+json" }
        ]
      },
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, must-revalidate" }
        ]
      },
      {
        "source": "/icons/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=2592000" }
        ]
      }
    ]
  }
}
