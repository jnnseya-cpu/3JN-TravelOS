# 3JN Travel OS — environment configuration example.
# Copy to ".env" and fill in. NEVER commit a real .env (it is git-ignored).

# Server
PORT=3000

# --- Persistence (Firebase Realtime Database) ----------------------------
# Optional. On Firebase Functions / Cloud Run, Application Default Credentials
# are present automatically and persistence activates. Locally, point
# GOOGLE_APPLICATION_CREDENTIALS at a service-account JSON to enable it; leave
# blank to run purely in-memory. The DB URL defaults to the project's RTDB.
FIREBASE_DATABASE_URL=https://studio-1885689950-9b056-default-rtdb.europe-west1.firebasedatabase.app/
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# --- Transactional email (Hostinger SMTP for info@3jntravel.com) ----------
# Sends booking confirmations + the contact form. Activates only when SMTP_PASS
# is set; otherwise the app runs without email. The password is a SECRET.
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=info@3jntravel.com
SMTP_PASS=
SMTP_FROM=3JN Travel OS <info@3jntravel.com>

# --- Rayna Tours B2B agent account (raynab2b.com) -------------------------
# Identifiers (non-secret) — defaults are baked in but can be overridden here.
RAYNA_PORTAL_URL=https://raynab2b.com/
RAYNA_AGENT_ID=AGT-48973
RAYNA_AGENT_EMAIL=info@3jntravel.com
# SECRET — required for a live Rayna booking integration. Leave blank for the
# offline prototype. Never commit a real value.
RAYNA_AGENT_PASSWORD=
RAYNA_API_KEY=

# --- AI Gateway / Model Router (Claude, OpenAI, Gemini) -------------------
# The gateway routes each task to the best provider. Keys are optional in the
# prototype (it falls back to a deterministic local engine). Provide to go live.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
AI_GATEWAY_DEFAULT_PROVIDER=anthropic
# Cohere (optional 4th provider in the model router)
COHERE_API_KEY=

# --- Security ---------------------------------------------------------------
# HMAC secret for the human-only signup/login challenge. Set a long random
# string in production (e.g. `openssl rand -hex 32`).
HUMAN_CHECK_SECRET=
# Lock CORS to your real domain(s) in production, e.g. https://3jntravel.com
CORS_ORIGIN=

# --- Live flight/hotel suppliers (optional; deterministic engine without) ---
DUFFEL_TOKEN=
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
OAG_SCHEDULES_KEY=
OAG_FLIGHTINFO_KEY=

# --- Stripe (reserved — card checkout integration is the next build step) ---
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Frontend publishable key goes in frontend config, not here: pk_live_...

# --- Google Maps (reserved — not required: stay/map links use keyless URLs) --
# GOOGLE_MAPS_API_KEY=
